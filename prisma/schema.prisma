generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================
// MODELOS DO CMS (PAINEL ADMIN)
// ============================================

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String   // Senha criptografada
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String
  thumbnail   String   // Caminho da imagem
  year        String
  location    String
  challenge   String   @db.Text
  concept     String   @db.Text
  materials   String   // Armazenado como JSON string ou texto simples separado por virgula
  images      String   @db.Text // Array de imagens armazenado como JSON string
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  time        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteContent {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  company   String?
  quote     String   @db.Text
  featured  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
